# MySQL remoto
# Formato Prisma:
# DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DB?connection_limit=10&pool_timeout=30"
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DB"

# Segurança
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"
PASSWORD_PEPPER="opcional-segredo-extra"

# App
APP_NAME="ProInova Jaborandi"
PUBLIC_BASE_URL="https://proinova.seudominio.com"

# VPS / Deploy (Configurar apenas no GitHub Secrets)
# VPS_HOST=
# VPS_USER=
# VPS_PORT=
# VPS_APP_DIR=
# VPS_SSH_PRIVATE_KEY=

# Integrações de I.A. (Prévia do Analista)
# QWEN_API_KEY=sk-xxxxxxxx  # Chave da Qwen (DashScope / Alibaba Cloud)
# DEEPSEEK_API_KEY=sk-xxxxxxxx # Chave do DeepSeek (Fallback)
